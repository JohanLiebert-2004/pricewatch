# /etc/nginx/sites-available/pricewatch — for the new pricewatch-db instance.
# Replace REPLACE_WITH_DASHED_IP with the instance's public IP, dashes
# instead of dots. certbot adds the TLS bits afterward.
server {
    listen 80;
    server_name REPLACE_WITH_DASHED_IP.sslip.io;

    location = /healthz { return 200 "ok\n"; }

    # Self-hosted PostgREST, replacing Supabase's REST API. Prefix stripped
    # the same way Supabase's own gateway does it, so existing frontend call
    # paths like /rest/v1/rpc/<fn> keep working unchanged - only the origin
    # they're fetched from is new.
    location /rest/v1/ {
        proxy_pass http://127.0.0.1:3000/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
